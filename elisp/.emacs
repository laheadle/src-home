(add-to-list 'load-path (concat l-elisp-home "lib/graph.el"))
(require 'graph)

(graph-draw-tree '(("C" ("D"))))

"
+---+
| C |
+-+-+
  |
  +
  |
+-+-+
| D |
+---+
"

(graph-draw-tree '(("C" ("D") ("E"))))

"
   +---+
   | C |
   +-+-+
     |
  +--+--+
  |     |
+-+-+ +-+-+
| D | | E |
+---+ +---+
"

(graph-draw-tree '(("B"
                    ("C" ("D") ("E"))
                    ("F"))))
"
   +---+
   | B |
   +-+-+
     |
  +--+--+
  |     |
+-+-+ +-+-+
| C | | F |
+-+-+ +---+
  |
  +-----+
  |     |
+-+-+ +-+-+
| D | | E |
+---+ +---+
"

(graph-draw-tree '(("B"
                    ("C" ("D") ("E"))
                    ("F")
                    ("H"))))
"
      +---+
      | B |
      +-+-+
        |
  +-----+-----+
  |     |     |
+-+-+ +-+-+ +-+-+
| C | | F | | H |
+-+-+ +---+ +---+
  |
  +-----+
  |     |
+-+-+ +-+-+
| D | | E |
+---+ +---+
"


(graph-draw-tree '(("B"
                    ("C"
                     ("D") ("E"))
                    ("F")
                    ("G"
                     ("H")
                     ("I")))))

"
         +---+
         | B |
         +-+-+
           |
     +-----+-----+
     |     |     |
   +-+-+ +-+-+ +-+-+
   | C | | F | | G |
   +-+-+ +---+ +-+-+
     |           |
  +--+--+     +--+--+
  |     |     |     |
+-+-+ +-+-+ +-+-+ +-+-+
| D | | E | | H | | I |
+---+ +---+ +---+ +---+
"
